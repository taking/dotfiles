Host taking-bastion
  HostName bastion.example.com
  User USERNAME
  Port 22
  IdentityFile ~/.ssh/taking/bastion_id_ed25519
  ServerAliveInterval 30
  ServerAliveCountMax 3

Host *-lxc-*
  User root
  ProxyJump taking-bastion
  IdentityFile ~/.ssh/taking/bastion_id_ed25519
  IdentitiesOnly yes
  PreferredAuthentications publickey
  #RequestTTY force
  #RemoteCommand /bin/bash -lc 'cd /mnt/docker; exec /bin/bash -l'
  
Host 200-lxc-svc
  HostName 10.10.0.10
  HostKeyAlias 200-lxc-svc
